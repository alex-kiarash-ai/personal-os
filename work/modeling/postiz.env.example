# Postiz env TEMPLATE. Copy to config/postiz.env (gitignored) and fill real values.
#   cp postiz.env.example config/postiz.env
# Never commit the filled file. Mirror JWT_SECRET + DB password into the password manager.
# Reconcile the variable set against the canonical gitroomhq/postiz-docker-compose at deploy time.

# --- URLs (the public subdomain, behind the box reverse proxy) ---
MAIN_URL=https://social.shaheenkiarash.com
FRONTEND_URL=https://social.shaheenkiarash.com
NEXT_PUBLIC_BACKEND_URL=https://social.shaheenkiarash.com/api
BACKEND_INTERNAL_URL=http://localhost:3000

# --- Auth ---
JWT_SECRET=__CHANGE_ME_long_random_string__

# --- Database (must match the postgres service creds below) ---
DATABASE_URL=postgresql://postiz-user:__DB_PASSWORD__@postiz-postgres:5432/postiz-db-local
POSTGRES_USER=postiz-user
POSTGRES_PASSWORD=__DB_PASSWORD__
POSTGRES_DB=postiz-db-local

# --- Redis ---
REDIS_URL=redis://postiz-redis:6379

# --- Storage (local disk on the box) ---
STORAGE_PROVIDER=local
UPLOAD_DIRECTORY=/uploads
NEXT_PUBLIC_UPLOAD_DIRECTORY=/uploads

# --- Lock down after the first account is created ---
DISABLE_REGISTRATION=true

# --- Instagram / Facebook (added at IG-connect time) ---
# Postiz posts to IG via the Instagram Graph API and needs a Facebook app.
# Requires @shaheen.kiarash to be an Instagram Business or Creator account linked to a Facebook page.
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
