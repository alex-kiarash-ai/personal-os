/// Jobs the gate routed to manual review, with scores and gate reasons.
table needs_review
	lineageTag: 0c90e13a-14fc-409b-9169-2c5d41aae17b

	measure 'Avg Fit (To Review)' = AVERAGE(needs_review[fit_score])
		formatString: 0.0
		lineageTag: 61a17366-4978-4004-a8a4-416d1e9a2a92

	column date
		dataType: dateTime
		formatString: Long Date
		lineageTag: 7529d503-d5b6-4bdb-998a-d94b5e238b3c
		summarizeBy: none
		sourceColumn: date

		variation Variation
			isDefault
			relationship: ae17e9cc-dcf0-402c-9154-81c8ac67537c
			defaultHierarchy: LocalDateTable_4fba07a1-ec1a-48b3-8966-9631d0952515.'Date Hierarchy'

		annotation UnderlyingDateTimeDataType = Date

		annotation SummarizationSetBy = Automatic

	column job_posting_id
