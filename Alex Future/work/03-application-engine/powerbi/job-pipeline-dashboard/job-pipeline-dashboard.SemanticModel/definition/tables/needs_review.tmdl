		summarizeBy: none
		sourceColumn: reasons

		annotation SummarizationSetBy = Automatic

	partition needs_review = m
		mode: import
		source = let Source = Excel.Workbook(File.Contents("C:\Users\Thinkpad\Desktop\personal-os\work\03-application-engine\powerbi\job-search-pipeline.xlsx"), null, true), Sheet = Source{[Item="needs_review",Kind="Sheet"]}[Data], Promoted = Table.PromoteHeaders(Sheet, [PromoteAllScalars=true]), Selected = Table.SelectColumns(Promoted, {"date", "job_posting_id", "job_title", "company_name", "job_location", "url", "fit_score", "interest_score", "rank_score", "reasons"}), Typed = Table.TransformColumnTypes(Selected, {{"date", type date}, {"job_posting_id", Int64.Type}, {"job_title", type text}, {"company_name", type text}, {"job_location", type text}, {"url", type text}, {"fit_score", Int64.Type}, {"interest_score", Int64.Type}, {"rank_score", Int64.Type}, {"reasons", type text}}) in Typed

