	column url
		dataType: string
		lineageTag: a3ffba41-430b-4bd8-8aa9-a85f7362654d
		summarizeBy: none
		sourceColumn: url

		annotation SummarizationSetBy = Automatic

	column fit_score
		dataType: int64
		lineageTag: 9da09776-92e0-4497-8339-d1918b92807d
