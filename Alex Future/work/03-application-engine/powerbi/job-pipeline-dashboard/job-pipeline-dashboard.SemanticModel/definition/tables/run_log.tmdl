	column drive_folder_url
		dataType: string
		lineageTag: 4757e186-c909-4671-af5a-1cbee0886bba
		summarizeBy: none
		sourceColumn: drive_folder_url

		annotation SummarizationSetBy = Automatic

	column job_url
		dataType: string
		lineageTag: 7b33e620-c6fa-4e7b-a167-e5aadb5335fd
		summarizeBy: none
		sourceColumn: job_url

		annotation SummarizationSetBy = Automatic

	column status
