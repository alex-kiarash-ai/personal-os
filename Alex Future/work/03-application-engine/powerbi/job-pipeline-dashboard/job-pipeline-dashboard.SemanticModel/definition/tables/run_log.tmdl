		annotation SummarizationSetBy = Automatic

	column country
		dataType: string
		lineageTag: 5c868273-0ad8-428a-be39-ff8cfeffb3c5
		summarizeBy: none
		sourceColumn: country

		annotation SummarizationSetBy = Automatic

	column fit_score
		dataType: int64
		lineageTag: 33a3b7cc-96f3-454e-bdb2-800aec1029a6
		summarizeBy: sum
		sourceColumn: fit_score

		annotation SummarizationSetBy = Automatic

	column interest_score
		dataType: int64
		lineageTag: 78dee857-29c6-4f71-9da4-a705948dd3fd
		summarizeBy: sum
		sourceColumn: interest_score

		annotation SummarizationSetBy = Automatic

	column rank_score
		dataType: int64
