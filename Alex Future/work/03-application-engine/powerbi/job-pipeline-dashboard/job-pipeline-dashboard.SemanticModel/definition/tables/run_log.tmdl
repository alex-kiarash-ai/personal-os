/// Jobs that passed the gate and have rendered CV + cover letter in Drive. status=draft_ready means waiting for Shaheen to submit.
table run_log
	lineageTag: 097fe5de-5e48-4b55-af52-1fb7429e7bcd

	measure 'Pipeline Cost (USD)' = SUM(run_log[total_cost])
		formatString: $0.000
		lineageTag: 18cc82e7-23dc-4602-84ed-2e413c89d11e

	column date
		dataType: dateTime
		formatString: Long Date
		lineageTag: 39aefcbf-ce3b-4afb-bf3e-49a4f9e4f879
		summarizeBy: none
		sourceColumn: date

		variation Variation
			isDefault
			relationship: 621b1b76-bbb5-430e-9f63-4e0aae7793b9
			defaultHierarchy: LocalDateTable_26858b8b-a4e0-4aa9-a1b6-1e0b40c34a0a.'Date Hierarchy'

		annotation UnderlyingDateTimeDataType = Date

		annotation SummarizationSetBy = Automatic

	column job_posting_id
		dataType: int64
		lineageTag: 78f7f67b-861b-47fe-ae31-699d03f90e50
		summarizeBy: sum
		sourceColumn: job_posting_id

		annotation SummarizationSetBy = Automatic

	column company
